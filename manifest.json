{
    "name": "Search Faster",
    "manifest_version": 3,
    "version": "1.0",
    "description": "Gives customizable shortcuts to search quickly",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "hello.html",
        "default_icon": "icon.png"
    },
    "commands": {
        "activate_search_mode": {
            "suggested_key": {
                "default": "Alt+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Turns on the extension"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts":[
        {
            "matches": ["*://www.google.com/search*"],
            "js": ["content.js"]
        } 
    ]
}

