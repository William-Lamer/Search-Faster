{
    "name": "Leaper",
    "manifest_version": 3,
    "version": "1.0",
    "description": "Gives shortcuts to navigate Google search results without a mouse.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "hello.html",
        "default_icon": "icon.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts":[
        {
            "matches": ["*://www.google.com/search*"],
            "js": ["content.js"]
        } 
    ]
}

